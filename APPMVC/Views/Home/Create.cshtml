@model APPMVC.Models.DocumentViewModel
@{
    ViewData["Title"] = "Thêm tài liệu";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card p-4 shadow-sm border-0 rounded bg-white">
            <h3 class="mb-4 text-primary text-center">Thêm tài liệu</h3>
            
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tiêu đề</label>
                    <input asp-for="Title" class="form-control"/>
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả chi tiết..."></textarea>
                </div>

                <div class="mb-4">
                    <label for="file" class="form-label fw-bold">Tệp đính kèm</label>
                    <input type="file" id="file" name="file" class="form-control" required />
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <button type="submit" class="btn btn-primary px-4">Lưu</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}