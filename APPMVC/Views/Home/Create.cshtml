@model APPMVC.Models.Post
@{
    ViewData["Title"] = "Tạo bài viết mới";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">Đăng bài viết mới</h4>
        </div>
        <div class="card-body">
            @* Form gửi dữ liệu đính kèm file cần có thuộc tính enctype="multipart/form-data" *@
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                
                @* CSRF Token dùng để bảo vệ form chống lại tấn công giả mạo yêu cầu từ trang khác *@
                @Html.AntiForgeryToken()

                <div class="text-danger" asp-validation-summary="ModelOnly"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label font-weight-bold">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label font-weight-bold">Nội dung bài viết</label>
                    <textarea asp-for="Content" rows="6" class="form-control" placeholder="Viết nội dung tại đây..."></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label for="files" class="form-label font-weight-bold">Tệp đính kèm (.jpg, .png, .pdf, .doc, .docx - Tối đa 5MB/file)</label>
                    <input type="file" id="files" name="files" class="form-control" multiple />
                    <small class="text-muted">Bạn có thể chọn nhiều file cùng lúc bằng cách giữ phím Ctrl.</small>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
                    <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Đăng bài viết</button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}