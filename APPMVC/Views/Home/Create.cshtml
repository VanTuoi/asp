@model APPMVC.Models.PostViewModel
@{
    ViewData["Title"] = "Tạo bài viết mới";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h4 class="mb-4">Đăng bài viết mới</h4>
                <form asp-action="Create" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <div class="text-danger" asp-validation-summary="ModelOnly"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Tiêu đề</label>
                        <input asp-for="Title" class="form-control" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label">Nội dung</label>
                        <textarea asp-for="Content" rows="6" class="form-control" required></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="mb-4">
                        <label for="files" class="form-label">Tệp đính kèm (Nhiều file)</label>
                        <input type="file" id="files" name="files" class="form-control" multiple />
                    </div>

                    <button type="submit" class="btn btn-primary">Đăng bài viết</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">Hủy</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}