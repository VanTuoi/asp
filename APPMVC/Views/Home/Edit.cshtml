@model APPMVC.Models.Post
@{
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-body">
                <h4 class="mb-4">Chỉnh sửa bài viết</h4>

                @if (ViewData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger">@ViewData["ErrorMessage"]</div>
                }

                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label">Tiêu đề</label>
                        <input asp-for="Title" class="form-control" required />
                        <span asp-validation-for="Title" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Content" class="form-label">Nội dung</label>
                        <textarea asp-for="Content" rows="6" class="form-control" required></textarea>
                        <span asp-validation-for="Content" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tệp đính kèm hiện tại</label>
                        <ul class="list-group">
                            @foreach (var a in Model.Attachments ?? [])
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center" id="attach-@a.Id">
                                    <a href="@a.FilePath" target="_blank">@a.FileName</a>
                                    <button type="button" class="btn btn-sm btn-danger" onclick="deleteAttach(@a.Id)">Xóa</button>
                                </li>
                            }
                        </ul>
                    </div>

                    <div class="mb-4">
                        <label for="files" class="form-label">Thêm tệp mới</label>
                        <input type="file" id="files" name="files" class="form-control" multiple />
                    </div>

                    <button type="submit" class="btn btn-primary">Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">Hủy</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function deleteAttach(id) {
            if (!confirm("Xóa tệp này?")) return;
            fetch(`/PostApi/DeleteAttachmentAjax?id=${id}`, { method: 'POST' })
                .then(r => r.json())
                .then(d => {
                    if (d.success) document.getElementById(`attach-${id}`).remove();
                    alert(d.message);
                });
        }
    </script>
}
