@model APPMVC.Models.DocumentViewModel
@{
    ViewData["Title"] = "Sửa tài liệu";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card p-4 shadow-sm border-0 rounded bg-white">
            <h3 class="mb-4 text-primary text-center">Sửa tài liệu</h3>

            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="All" class="text-danger small mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tiêu đề</label>
                    <input asp-for="Title" class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Mô tả</label>
                    <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                </div>

                <div class="mb-3 p-2 bg-light rounded small">
                    <span class="text-muted fw-bold">Tệp hiện tại:</span>
                    <a href="@Model.CurrentFilePath" target="_blank" class="text-decoration-none ms-1">@Model.CurrentFileName</a>
                </div>

                <div class="mb-4">
                    <label for="file" class="form-label fw-bold">Tải tệp mới (tùy chọn)</label>
                    <input type="file" id="file" name="file" class="form-control" />
                </div>

                <div class="d-flex justify-content-between align-items-center">
                    <button type="submit" class="btn btn-primary px-4">Cập nhật</button>
                    <a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
