@model APPMVC.Models.Post
@{
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0">Chỉnh sửa bài viết</h4>
        </div>
        <div class="card-body">
            @* Hỗ trợ tải file đính kèm mới *@
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                
                @* CSRF Token *@
                @Html.AntiForgeryToken()

                @* Hidden Input để mang theo ID *@
                <input type="hidden" asp-for="Id" />

                <div class="text-danger" asp-validation-summary="ModelOnly"></div>

                <div class="mb-3">
                    <label asp-for="Title" class="form-label font-weight-bold">Tiêu đề bài viết</label>
                    <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Content" class="form-label font-weight-bold">Nội dung bài viết</label>
                    <textarea asp-for="Content" rows="6" class="form-control" placeholder="Viết nội dung tại đây..."></textarea>
                    <span asp-validation-for="Content" class="text-danger"></span>
                </div>

                <!-- DANH SÁCH FILE ĐÍNH KÈM HIỆN TẠI -->
                <div class="mb-4">
                    <label class="form-label font-weight-bold">Tệp đính kèm hiện tại</label>
                    @if (Model.Attachments != null && Model.Attachments.Any())
                    {
                        <ul class="list-group mb-2" id="attachment-list">
                            @foreach (var attach in Model.Attachments)
                            {
                                <li class="list-group-item d-flex justify-content-between align-items-center" id="attach-item-@attach.Id">
                                    <a href="@attach.FilePath" target="_blank"><i class="bi bi-file-earmark-arrow-down"></i> @attach.FileName</a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="deleteAttachmentAjax(@attach.Id)">
                                        Xóa tệp
                                    </button>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <p class="text-muted" id="no-attachment-text">Không có tệp đính kèm nào.</p>
                    }
                </div>

                <!-- THÊM FILE ĐÍNH KÈM MỚI -->
                <div class="mb-3">
                    <label for="files" class="form-label font-weight-bold">Thêm tệp đính kèm mới (.jpg, .png, .pdf, .doc, .docx - Tối đa 5MB/file)</label>
                    <input type="file" id="files" name="files" class="form-control" multiple />
                    <small class="text-muted">Có thể chọn nhiều file đính kèm mới cùng lúc.</small>
                </div>

                <div class="d-flex justify-content-between mt-4">
                    <a asp-action="Index" class="btn btn-outline-secondary">Quay lại danh sách</a>
                    <button type="submit" class="btn btn-warning"><i class="bi bi-save"></i> Cập nhật bài viết</button>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function deleteAttachmentAjax(attachId) {
            if (confirm("Bạn có chắc chắn muốn xóa?")) {
                fetch(`/PostApi/DeleteAttachmentAjax?id=${attachId}`, { method: 'POST' })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        document.getElementById(`attach-item-${attachId}`)?.remove();
                        const list = document.getElementById('attachment-list');
                        if (list && list.children.length === 0) {
                            list.remove();
                            const noAttachHtml = '<p class="text-muted" id="no-attachment-text">Không có tệp đính kèm nào.</p>';
                            $('#attachment-list').parent().append(noAttachHtml);
                        }
                    }
                    alert(data.message);
                });
            }
        }
    </script>
}
