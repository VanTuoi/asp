@model APPMVC.Models.Post
@{
    ViewData["Title"] = Model.Title;
}

<div class="row justify-content-center mt-4">
    <div class="col-md-8">
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h2>@Model.Title</h2>
                <div class="text-muted mb-3">
                    Tác giả: <strong>@Model.AuthorName</strong> | Đăng lúc: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                </div>
                <hr />
                <div style="white-space: pre-line;">@Model.Content</div>
            </div>
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header">Tệp đính kèm</div>
            <div class="card-body">
                @if (Model.Attachments?.Any() == true)
                {
                    <ul class="list-group list-group-flush">
                        @foreach (var file in Model.Attachments)
                        {
                            <li class="list-group-item d-flex justify-content-between px-0">
                                @file.FileName
                                <a href="@file.FilePath" download="@file.FileName" class="btn btn-sm btn-outline-primary">Tải về</a>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <span class="text-muted">Không có đính kèm.</span>
                }
            </div>
        </div>

        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
    </div>
</div>
