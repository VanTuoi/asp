@model APPMVC.Models.Document
@{
    ViewData["Title"] = "Chi tiết tài liệu";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    bool canEditOrDelete = Model.UserId.ToString() == currentUserId || User.IsInRole("ADMIN");
}

<div class="row justify-content-center">
    <div class="col-md-7 col-lg-6">
        <div class="card p-4 shadow-sm border-0 rounded bg-white">
            <h3 class="text-primary mb-3 border-bottom pb-2">@Model.Title</h3>
            
            <div class="mb-3 small">
                <span class="text-muted">Người đăng: <strong>@Model.AuthorName</strong></span>
                <span class="text-muted mx-2">|</span>
                <span class="text-muted">Ngày tải lên: <strong>@Model.UploadedAt.ToString("dd/MM/yyyy HH:mm")</strong></span>
            </div>

            <div class="mb-4">
                <label class="fw-bold text-secondary">Mô tả chi tiết:</label>
                <div class="p-3 bg-light rounded mt-1" style="min-height: 80px; white-space: pre-wrap;">
                    @(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả." : Model.Description)
                </div>
            </div>

            <div class="mb-4">
                <span class="fw-bold text-secondary">Tệp đính kèm:</span>
                @if (!string.IsNullOrEmpty(Model.FilePath))
                {
                    <a href="@Model.FilePath" target="_blank" class="btn btn-sm btn-outline-info ms-2">@Model.FileName</a>
                }
                else
                {
                    <span class="text-muted small ms-2">Không có tệp đính kèm</span>
                }
            </div>

            <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                <a asp-action="Index" class="btn btn-sm btn-outline-secondary px-3">Quay lại</a>
                
                @if (canEditOrDelete)
                {
                    <div class="d-flex gap-2">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-warning text-white px-3">Sửa</a>
                        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('Xóa?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger px-3">Xóa</button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
