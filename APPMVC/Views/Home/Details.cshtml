@model APPMVC.Models.Post
@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4" style="max-width: 800px;">
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <h1 class="display-6">@Model.Title</h1>
            <div class="text-muted mb-3 d-flex align-items-center">
                <span class="me-3"><i class="bi bi-person"></i> Tác giả: <strong>@Model.AuthorName</strong></span>
                <span><i class="bi bi-calendar"></i> Đăng lúc: @Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <hr />
            <div class="post-content" style="white-space: pre-line; line-height: 1.6; font-size: 1.1rem;">
                @Model.Content
            </div>
        </div>
    </div>

    @* Danh sách tệp tin đính kèm *@
    <div class="card shadow-sm">
        <div class="card-header bg-light">
            <h5 class="mb-0"><i class="bi bi-paperclip"></i> Tài liệu / File đính kèm</h5>
        </div>
        <div class="card-body">
            @if (Model.Attachments != null && Model.Attachments.Count > 0)
            {
                <ul class="list-group list-group-flush">
                    @foreach (var file in Model.Attachments)
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <i class="bi bi-file-earmark-arrow-down text-primary me-2"></i>
                                @file.FileName
                            </div>
                            <a href="@file.FilePath" download="@file.FileName" class="btn btn-sm btn-outline-primary">
                                Tải về
                            </a>
                        </li>
                    }
                </ul>
            }
            else
            {
                <p class="text-muted mb-0">Bài viết này không có tệp đính kèm nào.</p>
            }
        </div>
    </div>

    <div class="mt-4 mb-5">
        <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
    </div>
</div>
