@model IEnumerable<APPMVC.Models.Document>
@{
    ViewData["Title"] = "Danh sách tài liệu";
    var currentUserId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    var isAdmin = User.IsInRole("ADMIN");
}

<h3 class="mb-4 text-primary">Tài liệu & Công văn</h3>

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" asp-action="Index" class="d-flex gap-2">
        <input type="text" name="search" class="form-control form-control-sm" placeholder="Tìm kiếm..." value="@ViewData["Search"]" style="width: 250px;" />
        <button type="submit" class="btn btn-sm btn-outline-primary">Tìm</button>
    </form>
    @if (User.Identity?.IsAuthenticated == true)
    {
        <a asp-action="Create" class="btn btn-sm btn-primary">Thêm tài liệu</a>
    }
</div>

<table class="table table-bordered table-striped table-hover align-middle shadow-sm bg-white rounded">
    <thead class="table-light">
        <tr>
            <th>Tiêu đề</th>
            <th>Người đăng</th>
            <th>Ngày tải lên</th>
            <th>Tệp</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @if (Model == null || !Model.Any())
        {
            <tr><td colspan="5" class="text-center text-muted py-3">Không có tài liệu nào.</td></tr>
        }
        else
        {
            foreach (var item in Model)
            {
                bool canEditOrDelete = item.UserId.ToString() == currentUserId || isAdmin;
                <tr>
                    <td><a asp-action="Details" asp-route-id="@item.Id" class="text-decoration-none fw-bold">@item.Title</a></td>
                    <td>@item.AuthorName</td>
                    <td>@item.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.FilePath))
                        {
                            <a href="@item.FilePath" target="_blank" class="text-decoration-none">@item.FileName</a>
                        }
                        else
                        {
                            <span class="text-muted small">Không có tệp</span>
                        }
                    </td>
                    <td>
                        @if (canEditOrDelete)
                        {
                            <div class="d-flex gap-2">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Xem</a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Xóa?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Xóa</button>
                                </form>
                            </div>
                        }
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

