@model APPMVC.Models.RegisterViewModel
@{
    ViewData["Title"] = "Đăng ký";
}

<h3>Đăng ký</h3>

<form asp-action="Register" method="post">
    <div asp-validation-summary="All" class="text-danger small mb-3"></div>

    <div class="mb-2">
        <label asp-for="Name">Họ tên</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-2">
        <label asp-for="Email">Email</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="mb-2">
        <label asp-for="Gender">Giới tính</label>
        <select asp-for="Gender" class="form-select">
            <option value="Nam">Nam</option>
            <option value="Nữ">Nữ</option>
        </select>
    </div>

    <div class="mb-2">
        <label asp-for="Password">Mật khẩu</label>
        <input asp-for="Password" type="password" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Role">Vai trò</label>
        <select asp-for="Role" class="form-select">
            <option value="USER">Người dùng</option>
            <option value="ADMIN">Quản trị viên</option>
        </select>
    </div>

    <button type="submit" class="btn btn-primary">Đăng ký</button>
    <a asp-action="Login" class="ms-2">Đăng nhập</a>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}